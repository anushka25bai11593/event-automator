def generate_creative_assets(event_name, theme):
    prompt = f"Act as a Creative Director. For an event named '{event_name}' with the theme '{theme}', suggest a 3-color hex palette, an Instagram caption, and a detailed Canva poster description."
    
    response = client.models.generate_content(
        model="gemini-2.0-flash", 
        contents=prompt
    )
    return response.text